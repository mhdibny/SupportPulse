{
  "ConnectionStrings": {
    "SqlServer": "Server=.;Database=SupportPulse_DB;Integrated Security=True;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Secrets": {
    "PasswordPepper": "YourPasswordPaper"
  },
  "FileUpload": {
    "MaxFileCount": 5,
    "MaxSizeBytes": 10485760, // 10 MB
    "AllowedExtensions": ".jpg,.jpeg,.png,.gif,.bmp,.pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.zip,.rar",
    "StoragePath": "UploadedFiles/Chats"
  },
  "Jwt": {
    "Key": "YourSecretKeyHere123456789012345"
  },
  "ChatAutoLockSettings": {
    "MaxActiveChatsPerAdmin": 5,
    "MaxTotalActiveChatsPerAdmin": 10,
    "AutoUnlockTimeoutMinutes": 5,
    "UnlockCheckIntervalMinutes": 10,
    "HeartbeatIntervalSeconds": 30,
    "ScoreWeightCapacity": 1000,
    "ScoreWeightEfficiency": 10,
    "ScoreWeightIdleMinutes": 5
  }
}
