@using SupportPulse.Core.DTOs.User
@using SupportPulse.Core.Services.Admin.Users
@using SupportPulse.Core.Services.Users
@using SupportPulse.Core.Utilities.ClaimsPrincipals
@inject IAdminUserService _adminUserService
@inject IUserService _userService

@{
    UserPanelInformationDto? userInfo = null;
    bool isAdmin = false;

    if (User.Identity?.IsAuthenticated is true)
    {
        int userId = User.GetUserIdAsInt();
        userInfo = await _userService.GetUserPanelInformationAsync(userId);
        isAdmin = await _adminUserService.IsThisUserAdminAsync(userId);
    }
}

<header class="main-header">
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="#">
                <span class="brand-icon"><i class="fas fa-bolt"></i></span>
                <span class="brand-text">SupportPulse</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#">خانه</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">چت</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">پشتیبانی</a></li>
                </ul>

                <div class="navbar-actions d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated is true)
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-light rounded-circle d-flex align-items-center justify-content-center"
                                    type="button"
                                    id="userMenuButton"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="width: 40px; height: 40px;">
                                <i class="fas fa-user"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuButton">
                                @if (isAdmin)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-action="Index" asp-controller="Home" asp-area="Admin">
                                            <i class="fas fa-crown me-2"></i> پنل ادمین
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <a class="dropdown-item" href="#"
                                       data-bs-toggle="modal" data-bs-target="#userInfoModal">
                                        <i class="fas fa-id-card me-2"></i> اطلاعات کاربری
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-action="Logout" asp-controller="Identity">
                                        <i class="fas fa-sign-out-alt me-2"></i> خروج
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-action="Login" asp-controller="Identity" class="btn btn-outline-light rounded-pill me-2">ورود</a>
                        <a asp-action="SignUp" asp-controller="Identity" class="btn btn-primary rounded-pill">ثبت‌نام</a>
                    }
                    <button id="themeToggle" class="theme-toggle-btn ms-2">
                        <i class="fas fa-sun"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>
</header>

@if (userInfo is not null)
{
    <div class="modal fade" id="userInfoModal" tabindex="-1" aria-labelledby="userInfoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="userInfoModalLabel">اطلاعات کاربری</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>نام کاربری:</strong> <span>@userInfo.UserName</span>
                        </li>
                        <li class="list-group-item">
                            <strong>نام:</strong> <span>@userInfo.FirstName</span>
                        </li>
                        <li class="list-group-item">
                            <strong>نام خانوادگی:</strong> <span>@userInfo.LastName</span>
                        </li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="modal fade" id="userInfoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    اطلاعات کاربر در دسترس نیست.
                </div>
            </div>
        </div>
    </div>
}