@* 404 Not Found *@
@{
    ViewData["Title"] = "صفحه پیدا نشد";
}
<div class="error-glass-wrapper">
    <div class="error-glass-card">
        <div class="error-illustration">
            <div class="circle-bg"></div>
            <div class="error-icon-svg">🧭</div>
            <div class="particles">
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
            </div>
        </div>
        <div class="error-code">۴۰۴</div>
        <h2 class="error-title">اوه! این صفحه قایم شده!</h2>
        <p class="error-description">
            انگار صفحه‌ای که دنبالشی تصمیم گرفته یه کم استراحت کنه یا کلاً کوچ کرده!
            نگران نباش، با دکمهٔ زیر می‌تونی برگردی خونه.
        </p>
        <div class="error-actions">
            <a href="/" class="error-btn error-btn-primary"><i class="fas fa-home"></i> بازگشت به خانه</a>
        </div>
    </div>
</div>