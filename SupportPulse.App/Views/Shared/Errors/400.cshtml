@* 400 Bad Request *@
@{
    ViewData["Title"] = "درخواست نامعتبر";
}
<div class="error-glass-wrapper">
    <div class="error-glass-card" style="--er-primary: #fbbf24; --er-gradient: linear-gradient(135deg, #fbbf24, #f97316);">
        <div class="error-illustration">
            <div class="circle-bg"></div>
            <div class="error-icon-svg">🤔</div>
            <div class="particles">
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
                <span class="particle"></span>
            </div>
        </div>
        <div class="error-code">۴۰۰</div>
        <h2 class="error-title">درخواستت عجیب غریبه!</h2>
        <p class="error-description">
            سرور نتونسته درخواست شما رو پردازش کنه. شاید یه چیزی رو اشتباه وارد کردی.
            نگاهی به آدرس و اطلاعاتت بنداز و دوباره امتحان کن. ما پشتت هستیم! 👍
        </p>
        <div class="error-actions">
            <a href="/" class="error-btn error-btn-primary"><i class="fas fa-home"></i> بازگشت به خانه</a>
        </div>
    </div>
</div>