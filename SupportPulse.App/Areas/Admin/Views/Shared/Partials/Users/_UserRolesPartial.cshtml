@* User roles assignment partial with local search and role cards *@
<div class="glass-card animate-fade-in-up">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0">مدیریت نقش‌های کاربر</h4>
        <button class="btn btn-outline-light btn-sm rounded-pill" onclick="loadPage('users')">
            <i class="fas fa-arrow-right"></i> بازگشت به لیست کاربران
        </button>
    </div>
    <div id="userRolesInfo" class="mb-3 text-secondary"></div>

    <div class="position-relative mb-3" style="max-width:300px;">
        <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
        <input type="text" id="roleSearchInputForUser" class="form-control ps-5" placeholder="جستجوی نقش..." autocomplete="off">
    </div>

    <div id="userRolesCardsContainer" class="user-roles-grid">
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    </div>

    <div class="mt-4 text-start">
        <button class="btn btn-primary" id="saveUserRolesBtn">
            <i class="fas fa-save"></i> ذخیره تغییرات
        </button>
    </div>
</div>