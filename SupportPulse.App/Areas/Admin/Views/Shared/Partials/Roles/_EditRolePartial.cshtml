@* Edit role page with a loading placeholder and a template that is filled by JavaScript *@
<div class="glass-card animate-fade-in-up">
    <div class="d-flex align-items-center mb-3">
        <button class="btn btn-outline-light btn-sm rounded-pill me-2" onclick="loadPage('roles')">
            <i class="fas fa-arrow-right"></i> بازگشت به لیست
        </button>
        <h4 class="mb-0">ویرایش نقش</h4>
    </div>
    <div id="roleEditContent">
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    </div>
</div>

<template id="roleEditFormTemplate">
    <form id="roleEditForm">
        <input type="hidden" id="editRoleId">
        <div class="mb-3">
            <label class="form-label">نام نقش</label>
            <input type="text" class="form-control" id="editRoleName" required>
        </div>
        <div class="mb-3">
            <label class="form-label">مجوزها</label>
            <div id="editPermissionsCheckboxes"></div>
        </div>
        <button type="button" class="btn btn-primary" id="saveEditRoleBtn">
            <i class="fas fa-save"></i> ذخیره تغییرات
        </button>
    </form>
</template>