@* Add new role form – permissions are populated by JavaScript *@
<div class="glass-card p-3">
    <h4 class="mb-3"><i class="fas fa-plus-circle"></i> افزودن نقش جدید</h4>

    <div class="mb-3">
        <label for="addRoleName" class="form-label">نام نقش</label>
        <input type="text" id="addRoleName" class="form-control" placeholder="نام نقش را وارد کنید...">
    </div>

    <div class="mb-3">
        <div class="permission-group-title">
            <i class="fas fa-cogs"></i> مجوزهای مدیریتی
        </div>
        <div class="permission-grid" id="addGeneralPermissions"></div>
    </div>

    <div class="mb-3">
        <div class="permission-group-title">
            <i class="fas fa-bell"></i> مجوزهای نوتیفیکیشن
        </div>
        <div class="permission-grid" id="addNotificationPermissions"></div>
    </div>

    <div class="d-flex gap-2">
        <button id="saveAddRoleBtn" class="btn btn-primary">
            <i class="fas fa-save"></i> ذخیره
        </button>
        <a href="/Admin/Roles" class="btn btn-outline-light">انصراف</a>
    </div>
</div>