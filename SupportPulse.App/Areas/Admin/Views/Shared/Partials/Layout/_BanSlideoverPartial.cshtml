@* Ban slide‑over panel *@
<div class="slide-over-backdrop" id="banSlideBackdrop" onclick="closeBanSlideover()"></div>
<div class="slide-over ban-slideover" id="banSlideover">
    <div class="slide-over-header">
        <div>
            <h5 class="slide-over-title" id="banSlideTitle">مدیریت مسدودیت</h5>
            <div id="banUserInfo" class="text-secondary small"></div>
        </div>
        <button class="btn-icon" onclick="closeBanSlideover()"><i class="fas fa-times"></i></button>
    </div>
    <div class="slide-over-body" id="banSlideBody">
        @* Content is populated by JavaScript *@
    </div>
</div>