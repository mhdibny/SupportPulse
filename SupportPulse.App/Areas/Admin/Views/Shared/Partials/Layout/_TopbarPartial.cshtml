@using SupportPulse.Core.DTOs.User
@using SupportPulse.Core.Services.Admin.Users
@using SupportPulse.Core.Services.Users
@using SupportPulse.Core.Utilities.ClaimsPrincipals
@inject IAdminUserService _adminUserService
@inject IUserService _userService

@{
    UserPanelInformationDto? userInfo = null;   

    if (User.Identity?.IsAuthenticated is true)
    {
        int userId = User.GetUserIdAsInt();
        userInfo = await _userService.GetUserPanelInformationAsync(userId);
    }
}

<header class="admin-topbar">
    <button id="sidebarToggle" class="btn-icon">
        <i class="fas fa-bars"></i>
    </button>
    <span id="pageTitle" class="topbar-title">چت‌ها</span>
    <div class="topbar-actions d-flex align-items-center">
        @if (User.Identity?.IsAuthenticated is true)
        {
            <div class="dropdown">
                <button class="btn btn-outline-light rounded-circle d-flex align-items-center justify-content-center"
                        type="button"
                        id="userMenuButton"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        style="width: 40px; height: 40px;">
                    <i class="fas fa-user"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuButton">
                    <li>
                        <a class="dropdown-item" href="/" title="بازگشت به بخش کاربری">
                            <i class="fas fa-home me-2"></i> بازگشت به بخش کاربری
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="#"
                           data-bs-toggle="modal" data-bs-target="#userInfoModal">
                            <i class="fas fa-id-card me-2"></i> اطلاعات کاربری
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-action="Logout" asp-controller="Identity">
                            <i class="fas fa-sign-out-alt me-2"></i> خروج
                        </a>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a asp-action="Login" asp-controller="Identity" class="btn btn-outline-light btn-sm rounded-pill">ورود</a>
        }

        @* Notification history bell *@
        <button id="adminNotifBell" class="btn-icon notification-bell ms-2" title="اعلان‌های مدیریتی">
            <i class="fas fa-bell"></i>
            <span class="badge" id="adminNotifBadge" style="display:none;">0</span>
        </button>

        <button id="themeToggle" class="theme-toggle-btn ms-2">
            <i class="fas fa-moon"></i>
        </button>
    </div>
</header>

@if (userInfo is not null)
{
    <div class="modal fade" id="userInfoModal" tabindex="-1" aria-labelledby="userInfoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="userInfoModalLabel">اطلاعات کاربری</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>نام کاربری:</strong> <span>@userInfo.UserName</span>
                        </li>
                        <li class="list-group-item">
                            <strong>نام:</strong> <span>@userInfo.FirstName</span>
                        </li>
                        <li class="list-group-item">
                            <strong>نام خانوادگی:</strong> <span>@userInfo.LastName</span>
                        </li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="modal fade" id="userInfoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    اطلاعات کاربر در دسترس نیست.
                </div>
            </div>
        </div>
    </div>
}