@* Add support category form *@
<div class="glass-card animate-fade-in-up">
    <div class="d-flex align-items-center mb-3">
        <button class="btn btn-outline-light btn-sm rounded-pill me-2" onclick="loadPage('categories')">
            <i class="fas fa-arrow-right"></i> بازگشت به لیست
        </button>
        <h4 class="mb-0">افزودن واحد پشتیبانی</h4>
    </div>
    <form id="addSupportCategoryForm">
        <div class="mb-3">
            <label class="form-label">نام واحد</label>
            <input type="text" id="addSupportCategoryName" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">توضیحات</label>
            <textarea id="addSupportCategoryDetails" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">آیکون (کلاس Font Awesome)</label>
            <input type="text" id="addSupportCategoryIcon" class="form-control" placeholder="مثلاً fas fa-headset">
        </div>
        <button type="button" class="btn btn-primary" id="saveAddSupportCategoryBtn">
            <i class="fas fa-save"></i> ذخیره
        </button>
    </form>
</div>