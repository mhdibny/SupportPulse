@* Edit support category page with a loading placeholder and a template filled by JavaScript *@
<div class="glass-card animate-fade-in-up">
    <div class="d-flex align-items-center mb-3">
        <button class="btn btn-outline-light btn-sm rounded-pill me-2" onclick="loadPage('categories')">
            <i class="fas fa-arrow-right"></i> بازگشت به لیست
        </button>
        <h4 class="mb-0">ویرایش واحد پشتیبانی</h4>
    </div>
    <div id="editSupportCategoryContent">
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    </div>
</div>

<template id="editSupportCategoryFormTemplate">
    <form id="editSupportCategoryForm">
        <input type="hidden" id="editSupportCategoryId">
        <div class="mb-3">
            <label class="form-label">نام واحد</label>
            <input type="text" id="editSupportCategoryName" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">توضیحات</label>
            <textarea id="editSupportCategoryDetails" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">آیکون</label>
            <input type="text" id="editSupportCategoryIcon" class="form-control" placeholder="انتخاب آیکون">
        </div>
        <div class="mb-3 form-switch">
            <input class="form-check-input" type="checkbox" id="editSupportCategoryIsActive">
            <label class="form-check-label" for="editSupportCategoryIsActive">فعال</label>
        </div>
        <div class="mb-3">
            <label class="form-label">کاربران دارای این واحد</label>
            <div id="editSupportCategoryUsersList" class="assigned-users-list"></div>
        </div>
        <button type="button" class="btn btn-primary" id="saveEditSupportCategoryBtn">
            <i class="fas fa-save"></i> ذخیره تغییرات
        </button>
    </form>
</template>