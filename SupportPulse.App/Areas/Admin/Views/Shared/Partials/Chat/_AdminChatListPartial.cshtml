@* Admin chat list sidebar and main area placeholder *@
<div id="notificationStack" class="notification-stack"></div>
<div class="chat-page-wrapper">
    <aside class="chat-sidebar" id="chatSidebar">
        <div class="chat-sidebar-header">
            <h3 class="chat-sidebar-title">چت‌ها</h3>
            <button class="btn btn-icon" id="chatSidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="chatFilterContainer"></div>
        <div class="chat-sidebar-body" id="adminChatListContainer">
            <div class="text-center py-5 text-secondary">
                <div class="spinner-border spinner-border-sm text-primary mb-2"></div>
                <p>در حال بارگذاری...</p>
            </div>
        </div>
    </aside>

    <main class="chat-main-area" id="chatMainArea">
        <div class="chat-placeholder">
            <i class="fas fa-comment-dots fa-3x mb-3"></i>
            <p>یک چت را برای مشاهده انتخاب کنید</p>
        </div>
    </main>
</div>